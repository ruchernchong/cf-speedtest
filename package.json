{
  "name": "cf-speedtest",
  "version": "0.2.4",
  "description": "CLI tool for testing internet speed using Cloudflare's network",
  "keywords": [
    "speedtest",
    "cloudflare",
    "cli",
    "network",
    "bandwidth",
    "latency",
    "internet-speed",
    "performance",
    "testing"
  ],
  "author": "Ru Chern Chong <hello@ruchern.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruchernchong/cf-speedtest.git"
  },
  "homepage": "https://github.com/ruchernchong/cf-speedtest#readme",
  "bugs": {
    "url": "https://github.com/ruchernchong/cf-speedtest/issues"
  },
  "type": "module",
  "module": "src/index.ts",
  "main": "dist/index.js",
  "files": ["dist"],
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "cf-speedtest": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "biome check src/**",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@commitlint/types": "^20.4.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@vitest/coverage-v8": "3.1.4",
    "lint-staged": "^16.2.7",
    "semantic-release": "^25.0.3",
    "husky": "^9.1.7",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.4"
  },
  "lint-staged": {
    "*": ["biome check --write --no-errors-on-unmatched"]
  }
}
