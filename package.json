{
  "name": "cf-speedtest",
  "version": "0.2.4",
  "description": "CLI tool for testing internet speed using Cloudflare's network",
  "keywords": [
    "speedtest",
    "cloudflare",
    "cli",
    "network",
    "bandwidth",
    "latency",
    "internet-speed",
    "performance",
    "testing"
  ],
  "author": "Ru Chern Chong <hello@ruchern.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruchernchong/cf-speedtest.git"
  },
  "homepage": "https://github.com/ruchernchong/cf-speedtest#readme",
  "bugs": {
    "url": "https://github.com/ruchernchong/cf-speedtest/issues"
  },
  "type": "module",
  "module": "src/index.ts",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "cf-speedtest": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "format": "biome format src",
    "release": "semantic-release",
    "prepare": "husky"
  },
  "dependencies": {
    "@cloudflare/speedtest": "^1.7.0",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@commitlint/types": "^20.4.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@vitest/coverage-v8": "4.0.18",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
